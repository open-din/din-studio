{
  "name": "din-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone DIN Studio editor, desktop app targets, and MCP server built on @open-din/react",
  "type": "module",
  "scripts": {
    "dev:web": "vite --config targets/web/vite.config.ts",
    "build:web": "vite build --config targets/web/vite.config.ts",
    "dev:app": "node ./scripts/dev-app.mjs",
    "build:app": "node ./scripts/build-app.mjs",
    "build:mcp": "node --enable-source-maps ./node_modules/tsup/dist/cli-default.js --config targets/mcp/tsup.config.ts",
    "dev:mcp": "node ./scripts/run-mcp.mjs dev",
    "mcp:start": "node ./scripts/run-mcp.mjs start",
    "dev:stack": "node ./scripts/dev-stack.mjs",
    "test:unit": "vitest --config vitest.config.ts --run",
    "test:mcp": "node ./node_modules/vitest/vitest.mjs --config targets/mcp/vitest.config.ts --run",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:mcp",
    "build:din-wasm": "wasm-pack build ../din-core/crates/din-wasm --target web --out-dir ../../din-studio/vendor/din-wasm-pkg",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p targets/mcp/tsconfig.json --noEmit && tsc -p targets/app/tsconfig.json --noEmit",
    "validate:manifests": "node ./scripts/validate-manifests.mjs",
    "validate:docs": "node ./scripts/validate-docs.mjs",
    "docs:generate": "typedoc",
    "ci:check": "npm run lint && npm run typecheck && npm run validate:manifests && npm run validate:docs && npm run test && npm run test:e2e",
    "prepare": "husky"
  },
  "dependencies": {
    "@grame/faustwasm": "^0.16.1",
    "@open-din/react": "file:../react-din",
    "@xyflow/react": "^12.10.0",
    "din-wasm": "file:./vendor/din-wasm-pkg",
    "lamejs": "^1.2.1",
    "lucide-react": "^1.7.0",
    "openai": "^4.104.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.18.3",
    "yaml": "^2.8.3",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.20",
    "electron": "^35.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-jsdoc": "^50.6.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.24",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.0.0",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.4.0",
    "typescript": "^5.3.0",
    "vite": "^7.2.4",
    "vitest": "^1.0.0"
  }
}
