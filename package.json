{
  "name": "din-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone DIN Studio editor, desktop app targets, and MCP server built on @din/react",
  "type": "module",
  "scripts": {
    "dev:web": "vite --config targets/web/vite.config.ts",
    "build:web": "vite build --config targets/web/vite.config.ts",
    "dev:app": "vite --config targets/app/vite.config.ts",
    "build:app": "node ./scripts/build-app.mjs",
    "build:mcp": "node --enable-source-maps ./node_modules/tsup/dist/cli-default.js --config targets/mcp/tsup.config.ts",
    "dev:mcp": "node ./scripts/run-mcp.mjs dev",
    "mcp:start": "node ./scripts/run-mcp.mjs start",
    "dev:stack": "node ./scripts/dev-stack.mjs",
    "test:unit": "vitest --config vitest.config.ts --run",
    "test:mcp": "node ./node_modules/vitest/vitest.mjs --config targets/mcp/vitest.config.ts --run",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:mcp",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p targets/mcp/tsconfig.json --noEmit && tsc -p targets/app/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@din/react": "^0.1.0",
    "@xyflow/react": "^12.10.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.18.3",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.20",
    "electron": "^35.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^1.0.0"
  }
}
